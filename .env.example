# SMTP 邮件服务配置
# 请根据你的邮箱服务提供商填写以下配置

# SMTP 服务器地址
# QQ邮箱: smtp.qq.com
# 163邮箱: smtp.163.com
# Gmail: smtp.gmail.com
# 阿里云企业邮箱: smtp.qiye.aliyun.com
SMTP_HOST=smtp.163.com

# SMTP 端口
# 465 (SSL加密)
# 587 (TLS加密)
# 25 (不加密，不推荐)
SMTP_PORT=465

# SMTP 用户名（通常是你的邮箱地址）
SMTP_USER=your-email@163.com

# SMTP 密码或授权码
# 注意：QQ邮箱、163邮箱等需要使用授权码，而不是登录密码
# 获取授权码：
# - QQ邮箱: 设置 -> 账户 -> POP3/SMTP服务 -> 开启服务 -> 生成授权码
# - 163邮箱: 设置 -> POP3/SMTP/IMAP -> 开启服务 -> 获取授权码
SMTP_PASS=your-authorization-code

# 发件人邮箱地址（可选，默认使用 SMTP_USER）
# SMTP_FROM=noreply@yourdomain.com
