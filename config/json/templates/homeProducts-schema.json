{
  "title": "产品展示配置",
  "description": "配置首页产品展示区域的内容",
  "type": "object",
  "properties": {
    "products": {
      "type": "object",
      "title": "产品展示配置",
      "properties": {
        "title": {
          "type": "string",
          "title": "区块标题",
          "ui": {"widget": "input", "width": "100%"}
        },
        "description": {
          "type": "string",
          "title": "区块描述",
          "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
        },
        "items": {
          "type": "array",
          "title": "产品列表",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "title": "产品ID",
                "ui": {"widget": "input", "width": "25%"}
              },
              "name": {
                "type": "string",
                "title": "产品名称",
                "ui": {"widget": "input", "width": "75%"}
              },
              "description": {
                "type": "string",
                "title": "产品描述",
                "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
              },
              "icon": {
                "type": "string",
                "title": "图标名称",
                "description": "图标组件名称，如 IconThunderbolt",
                "ui": {"widget": "input", "width": "50%"}
              },
              "tag": {
                "type": "string",
                "title": "标签文字",
                "ui": {"widget": "input", "width": "25%"}
              },
              "tagColor": {
                "type": "string",
                "title": "标签颜色",
                "enum": [
                  {"value": "blue", "label": "蓝色"},
                  {"value": "green", "label": "绿色"},
                  {"value": "orange", "label": "橙色"},
                  {"value": "purple", "label": "紫色"}
                ],
                "ui": {"widget": "select", "width": "25%"}
              },
              "features": {
                "type": "array",
                "title": "特性列表",
                "items": {"type": "string"},
                "ui": {"widget": "tags", "placeholder": "输入特性后按回车添加", "width": "100%"}
              },
              "link": {
                "type": "string",
                "title": "链接地址",
                "ui": {"widget": "input", "width": "100%"}
              }
            }
          },
          "ui": {"widget": "array", "itemTitle": "产品项", "width": "100%"}
        }
      }
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left",
    "groups": [
      {
        "title": "产品展示配置",
        "fields": ["products"]
      }
    ]
  }
}
