{
  "title": "产品列表配置",
  "description": "配置产品分类和产品列表",
  "type": "object",
  "properties": {
    "products": {
      "type": "object",
      "title": "产品配置",
      "properties": {
        "categories": {
          "type": "array",
          "title": "产品分类",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string",
                "title": "分类键",
                "ui": {"widget": "input", "width": "50%"}
              },
              "title": {
                "type": "string",
                "title": "分类名称",
                "ui": {"widget": "input", "width": "50%"}
              }
            }
          },
          "ui": {"widget": "array", "itemTitle": "分类", "width": "100%"}
        },
        "items": {
          "type": "array",
          "title": "产品列表",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "title": "产品ID",
                "ui": {"widget": "input", "width": "33%"}
              },
              "title": {
                "type": "string",
                "title": "产品名称",
                "ui": {"widget": "input", "width": "67%"}
              },
              "description": {
                "type": "string",
                "title": "产品描述",
                "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
              },
              "price": {
                "type": "number",
                "title": "价格",
                "ui": {"widget": "input", "width": "33%"}
              },
              "originalPrice": {
                "type": "number",
                "title": "原价",
                "ui": {"widget": "input", "width": "33%"}
              },
              "image": {
                "type": "string",
                "title": "图片路径",
                "ui": {"widget": "input", "width": "34%"}
              },
              "tags": {
                "type": "array",
                "title": "标签",
                "items": {"type": "string"},
                "ui": {"widget": "tags", "placeholder": "输入标签后按回车添加", "width": "100%"}
              },
              "category": {
                "type": "string",
                "title": "分类",
                "ui": {"widget": "input", "width": "100%"}
              }
            }
          },
          "ui": {"widget": "array", "itemTitle": "产品", "width": "100%"}
        }
      }
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left",
    "groups": [
      {
        "title": "产品配置",
        "fields": ["products"]
      }
    ]
  }
}
