{
  "title": "站点配置",
  "description": "配置网站的基本信息",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "网站名称",
      "description": "显示在Header、Footer等位置",
      "required": true,
      "ui": {
        "widget": "input",
        "placeholder": "请输入网站名称",
        "width": "100%"
      }
    },
    "description": {
      "type": "string",
      "title": "网站描述",
      "description": "用于SEO和网站介绍",
      "required": true,
      "ui": {
        "widget": "textarea",
        "placeholder": "请输入网站描述",
        "rows": 3,
        "width": "100%"
      }
    },
    "url": {
      "type": "string",
      "title": "网站URL",
      "description": "用于生成绝对路径链接",
      "required": true,
      "format": "uri",
      "ui": {
        "widget": "input",
        "placeholder": "https://example.com",
        "width": "100%"
      }
    },
    "ogImage": {
      "type": "string",
      "title": "Open Graph图片",
      "description": "用于社交分享的图片路径",
      "required": false,
      "ui": {
        "widget": "input",
        "placeholder": "/og-image.png",
        "width": "100%"
      }
    },
    "icp": {
      "type": "string",
      "title": "ICP备案号",
      "description": "网站ICP备案号",
      "required": false,
      "ui": {
        "widget": "input",
        "placeholder": "浙ICP备XXXXXXXX号",
        "width": "100%"
      }
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left",
    "groups": [
      {
        "title": "基本信息",
        "fields": [
          "name",
          "description",
          "url",
          "ogImage",
          "icp"
        ]
      }
    ]
  }
}