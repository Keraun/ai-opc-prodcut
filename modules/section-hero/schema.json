        "main": {
          "type": "string",
          "title": "主标题",
          "default": "让AI成为你的"
        },
        "sub": {
          "type": "string",
          "title": "副标题",
          "default": "超级员工"
        },
        "highlight": {
          "type": "string",
          "title": "高亮文本",
          "default": ""
        }
      },
      "default": {
        "main": "让AI成为你的",
        "sub": "超级员工",
        "highlight": ""
      }
    },
    "subtitle": {
      "type": "string",
      "title": "副标题描述",
      "default": "为个人创业者提供AI工具、课程和工作流，助力一人公司实现10倍效率提升"
    },
    "buttons": {
      "type": "object",
      "title": "按钮配置",
