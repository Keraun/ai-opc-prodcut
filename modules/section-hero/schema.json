          "type": "object",
          "title": "主要按钮",
          "properties": {
            "text": {
              "type": "string",
              "title": "按钮文本",
              "default": "开始探索"
            },
            "href": {
              "type": "string",
              "title": "链接地址",
              "default": "/products"
            }
          },
          "default": {
            "text": "开始探索",
            "href": "/products"
          }
        },
        "secondary": {
          "type": "object",
          "title": "次要按钮",
          "properties": {
            "text": {
              "type": "string",
              "title": "按钮文本",
              "default": "了解更多"
            },
            "href": {
              "type": "string",
              "title": "链接地址",
              "default": "/about"
            }
          },
          "default": {
            "text": "了解更多",
            "href": "/about"
          }
        }
      },
      "default": {
        "primary": {
          "text": "开始探索",
          "href": "/products"
        },
        "secondary": {
          "text": "了解更多",
          "href": "/about"
        }
      }
    },
    "featurePills": {
      "type": "array",
      "title": "特性标签",
      "items": {
        "type": "string"
