{
  "type": "object",
  "title": "Hero Section Configuration",
  "properties": {
    "layout": {
      "type": "string",
      "title": "布局样式",
      "enum": ["layout1", "layout2", "layout3"],
      "default": "layout1"
    },
    "badge": {
      "type": "string",
      "title": "徽章文本",
      "default": "专注AI一人公司服务"
    },
    "title": {
      "type": "object",
      "title": "标题配置",
