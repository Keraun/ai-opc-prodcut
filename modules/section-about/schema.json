{
  "title": "关于我们配置",
  "description": "配置首页关于我们区域的内容",
  "type": "object",
  "properties": {
    "sectionTag": {
      "type": "string",
      "title": "区块标签",
      "ui": {"widget": "input", "width": "100%"}
    },
    "title": {
      "type": "object",
      "title": "标题配置",
      "properties": {
        "main": {
          "type": "string",
          "title": "主标题",
          "ui": {"widget": "input", "width": "100%"}
        },
        "highlight": {
          "type": "string",
          "title": "高亮文字",
          "ui": {"widget": "input", "width": "100%"}
        }
      }
    },
    "description": {
      "type": "array",
      "title": "描述列表",
      "items": {"type": "string"},
      "ui": {"widget": "tags", "placeholder": "输入描述后按回车添加", "width": "100%"}
    },
    "mission": {
      "type": "object",
      "title": "使命",
      "properties": {
        "title": {
          "type": "string",
          "title": "标题",
          "ui": {"widget": "input", "width": "100%"}
        },
        "description": {
          "type": "string",
          "title": "描述",
          "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
        }
      }
    },
    "vision": {
      "type": "object",
      "title": "愿景",
      "properties": {
        "title": {
          "type": "string",
          "title": "标题",
          "ui": {"widget": "input", "width": "100%"}
        },
        "description": {
          "type": "string",
          "title": "描述",
          "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
        }
      }
    },
    "values": {
      "type": "object",
      "title": "价值观",
      "properties": {
        "title": {
          "type": "string",
          "title": "标题",
          "ui": {"widget": "input", "width": "100%"}
        },
        "description": {
          "type": "string",
          "title": "描述",
          "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
        }
      }
    },
    "stats": {
      "type": "array",
      "title": "统计数据",
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "数值",
            "ui": {"widget": "input", "width": "100%"}
          },
          "label": {
            "type": "string",
            "title": "标签",
            "ui": {"widget": "input", "width": "100%"}
          }
        }
      },
      "ui": {"widget": "array", "itemTitle": "统计项", "width": "100%"}
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left"
  }
}
