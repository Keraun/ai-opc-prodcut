{
  "type": "object",
  "title": "站点容器",
  "description": "网站全局配置，包括基本信息、联系方式、SEO设置等",
  "properties": {
    "name": {
      "type": "string",
      "title": "站点名称",
      "description": "网站的名称，显示在浏览器标签页和页头",
      "default": ""
    },
    "description": {
      "type": "string",
      "title": "站点描述",
      "description": "网站的简短描述，用于SEO和社交分享",
      "default": ""
    },
    "url": {
      "type": "string",
      "title": "站点URL",
      "description": "网站的完整URL地址",
      "default": ""
    },
    "ogImage": {
      "type": "string",
      "title": "OG图片",
      "description": "社交分享时显示的图片路径",
      "default": "/og-image.png",
      "ui": {
        "widget": "image",
        "placeholder": "请输入OG图片链接或点击上传"
      }
    },
    "icp": {
      "type": "string",
      "title": "ICP备案号",
      "description": "网站ICP备案号",
      "default": ""
    },

    "links": {
      "type": "object",
      "title": "社交链接",
      "description": "配置网站的社交媒体链接",
      "properties": {
        "email": {
          "type": "string",
          "title": "邮箱",
          "description": "联系邮箱地址"
        },
        "wechat": {
          "type": "string",
          "title": "微信公众号二维码",
          "description": "微信公众号二维码图片",
          "ui": {
            "widget": "image",
            "placeholder": "请输入公众号二维码图片链接或点击上传"
          }
        },
        "github": {
          "type": "string",
          "title": "GitHub",
          "description": "GitHub 仓库链接"
        },
        "twitter": {
          "type": "string",
          "title": "Twitter",
          "description": "Twitter 链接"
        }
      }
    },
    "creator": {
      "type": "object",
      "title": "创建者信息",
      "description": "配置网站创建者信息",
      "properties": {
        "name": {
          "type": "string",
          "title": "创建者名称",
          "description": "创建者或公司名称"
        },
        "url": {
          "type": "string",
          "title": "创建者链接",
          "description": "创建者的网站链接"
        }
      }
    },
    "contact": {
      "type": "object",
      "title": "联系方式",
      "description": "配置网站联系信息",
      "properties": {
        "address": {
          "type": "string",
          "title": "地址",
          "description": "公司或办公地址"
        },
        "phone": {
          "type": "string",
          "title": "电话",
          "description": "联系电话号码"
        },
        "email": {
          "type": "string",
          "title": "邮箱",
          "description": "联系邮箱地址"
        }
      }
    },
    "support": {
      "type": "object",
      "title": "客服支持",
      "description": "配置客服和帮助文档相关设置",
      "properties": {
        "customerServiceQRCode": {
          "type": "string",
          "title": "客服二维码",
          "description": "客服微信二维码图片路径",
          "default": "/images/customer-service-qr.png",
          "ui": {
            "widget": "image",
            "placeholder": "请输入客服二维码图片链接或点击上传"
          }
        },
        "helpDocUrl": {
          "type": "string",
          "title": "帮助文档链接",
          "description": "帮助文档的链接地址"
        }
      }
    },
    "features": {
      "type": "object",
      "title": "功能开关",
      "description": "启用或禁用网站的各项功能",
      "properties": {
        "enableTOC": {
          "type": "boolean",
          "title": "启用目录",
          "description": "显示文章目录导航",
          "default": true
        },
        "enableReadingProgress": {
          "type": "boolean",
          "title": "启用阅读进度条",
          "description": "显示页面阅读进度",
          "default": true
        },
        "enableSearch": {
          "type": "boolean",
          "title": "启用搜索",
          "description": "启用站内搜索功能",
          "default": true
        }
      }
    },
    "seo": {
      "type": "object",
      "title": "SEO设置",
      "description": "配置网站搜索引擎优化相关设置",
      "properties": {
        "keywords": {
          "type": "array",
          "title": "关键词",
          "description": "网站SEO关键词列表",
          "x-component": "tags",
          "items": {
            "type": "string"
          }
        },
        "robots": {
          "type": "object",
          "title": "爬虫设置",
          "description": "配置搜索引擎爬虫规则",
          "properties": {
            "index": {
              "type": "boolean",
              "title": "允许索引",
              "description": "是否允许搜索引擎索引网站",
              "default": true
            },
            "follow": {
              "type": "boolean",
              "title": "允许跟踪链接",
              "description": "是否允许搜索引擎跟踪页面链接",
              "default": true
            },
            "googleBot": {
              "type": "object",
              "title": "Google爬虫设置",
              "description": "Google搜索引擎爬虫的高级设置",
              "properties": {
                "index": {
                  "type": "boolean",
                  "title": "允许索引",
                  "description": "是否允许Google爬虫索引",
                  "default": true
                },
                "follow": {
                  "type": "boolean",
                  "title": "允许跟踪链接",
                  "description": "是否允许Google爬虫跟踪链接",
                  "default": true
                },
                "maxVideoPreview": {
                  "type": "number",
                  "title": "最大视频预览数",
                  "description": "视频预览的最大数量，-1表示不限制",
                  "default": -1
                },
                "maxImagePreview": {
                  "type": "string",
                  "title": "最大图片预览",
                  "description": "图片预览的大小设置",
                  "default": "large",
                  "enum": ["none", "standard", "large"]
                },
                "maxSnippet": {
                  "type": "number",
                  "title": "最大摘要长度",
                  "description": "搜索结果摘要的最大长度，-1表示不限制",
                  "default": -1
                }
              }
            }
          }
        }
      }
    }
  }
}