{
  "type": "object",
  "title": "站点配置",
  "properties": {
    "name": {
      "type": "string",
      "title": "站点名称"
    },
    "description": {
      "type": "string",
      "title": "站点描述"
    },
    "url": {
      "type": "string",
      "title": "站点URL"
    },
    "ogImage": {
      "type": "string",
      "title": "OG图片路径"
    },
    "links": {
      "type": "object",
      "title": "社交链接",
      "properties": {
        "email": {
          "type": "string",
          "title": "邮箱"
        },
        "wechat": {
          "type": "string",
          "title": "微信公众号"
        },
        "github": {
          "type": "string",
          "title": "GitHub"
        },
        "twitter": {
          "type": "string",
          "title": "Twitter"
        }
      }
    },
    "creator": {
      "type": "object",
      "title": "创建者信息",
      "properties": {
        "name": {
          "type": "string",
          "title": "创建者名称"
        },
        "url": {
          "type": "string",
          "title": "创建者链接"
        }
      }
    },
    "contact": {
      "type": "object",
      "title": "联系方式",
      "properties": {
        "address": {
          "type": "string",
          "title": "地址"
        },
        "phone": {
          "type": "string",
          "title": "电话"
        },
        "email": {
          "type": "string",
          "title": "邮箱"
        }
      }
    },
    "support": {
      "type": "object",
      "title": "支持信息",
      "properties": {
        "customerServiceQRCode": {
          "type": "string",
          "title": "客服二维码"
        },
        "helpDocUrl": {
          "type": "string",
          "title": "帮助文档链接"
        }
      }
    },
    "icp": {
      "type": "string",
      "title": "ICP备案号"
    },
    "features": {
      "type": "object",
      "title": "功能开关",
      "properties": {
        "enableTOC": {
          "type": "boolean",
          "title": "启用目录"
        },
        "enableReadingProgress": {
          "type": "boolean",
          "title": "启用阅读进度"
        },
        "enableSearch": {
          "type": "boolean",
          "title": "启用搜索"
        }
      }
    },
    "seo": {
      "type": "object",
      "title": "SEO配置",
      "properties": {
        "keywords": {
          "type": "array",
          "title": "关键词列表",
          "items": {
            "type": "string"
          }
        },
        "robots": {
          "type": "object",
          "title": "Robots配置",
          "properties": {
            "index": {
              "type": "boolean",
              "title": "允许索引"
            },
            "follow": {
              "type": "boolean",
              "title": "允许跟踪"
            },
            "googleBot": {
              "type": "object",
              "title": "Google Bot配置",
              "properties": {
                "index": {
                  "type": "boolean",
                  "title": "允许索引"
                },
                "follow": {
                  "type": "boolean",
                  "title": "允许跟踪"
                },
                "maxVideoPreview": {
                  "type": "number",
                  "title": "最大视频预览"
                },
                "maxImagePreview": {
                  "type": "string",
                  "title": "最大图片预览",
                  "enum": ["none", "standard", "large"]
                },
                "maxSnippet": {
                  "type": "number",
                  "title": "最大摘要长度"
                }
              }
            }
          }
        }
      }
    },
    "currentTheme": {
      "type": "string",
      "title": "当前主题"
    }
  }
}
