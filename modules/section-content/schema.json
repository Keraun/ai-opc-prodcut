{
  "type": "object",
  "title": "内容区块配置",
  "description": "配置内容区块的标题和富文本内容",
  "properties": {
    "title": {
      "type": "string",
      "title": "区块标题",
      "description": "内容区块的可选标题"
    },
    "content": {
      "type": "string",
      "title": "富文本内容",
      "description": "主要的富文本内容",
      "x-component": "richtext"
    },
    "contentLayout": {
      "type": "string",
      "title": "布局样式",
      "description": "选择内容区块的布局样式",
      "enum": ["default", "section", "article"],
      "default": "default"
    },
    "marginTop": {
      "type": "string",
      "title": "上外边距",
      "description": "设置内容区块的上外边距",
      "default": "3rem"
    },
    "marginBottom": {
      "type": "string",
      "title": "下外边距",
      "description": "设置内容区块的下外边距",
      "default": "3rem"
    }
  }
}
