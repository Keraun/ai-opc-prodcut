{
  "title": "顶部导航配置",
  "description": "配置网站顶部导航栏",
  "type": "object",
  "properties": {
    "navItems": {
      "type": "array",
      "title": "导航菜单",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "title": "菜单名称",
            "ui": {"widget": "input", "width": "50%", "required": true}
          },
          "href": {
            "type": "string",
            "title": "链接地址",
            "ui": {"widget": "input", "width": "50%", "required": true}
          }
        }
      },
      "ui": {"widget": "array", "itemTitle": "导航项", "width": "100%"}
    },
    "showContactButton": {
      "type": "boolean",
      "title": "显示联系按钮",
      "default": true,
      "ui": {"widget": "switch", "width": "33%"}
    },
    "showCtaButton": {
      "type": "boolean",
      "title": "显示CTA按钮",
      "default": true,
      "ui": {"widget": "switch", "width": "33%"}
    },
    "ctaButtonText": {
      "type": "string",
      "title": "CTA按钮文字",
      "default": "开始使用",
      "ui": {"widget": "input", "width": "50%"}
    },
    "ctaButtonLink": {
      "type": "string",
      "title": "CTA按钮链接",
      "default": "/products",
      "ui": {"widget": "input", "width": "50%"}
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left"
  }
}
