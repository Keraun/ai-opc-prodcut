{
  "type": "object",
  "title": "Header Configuration",
  "properties": {
    "navItems": {
      "type": "array",
      "title": "导航项列表",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "title": "标签",
            "default": ""
          },
          "href": {
            "type": "string",
            "title": "链接地址",
            "default": ""
          }
        },
        "default": {
          "label": "",
          "href": ""
        }
      },
      "default": [
        { "label": "首页", "href": "/" },
        { "label": "产品", "href": "/products" },
        { "label": "服务", "href": "/services" },
        { "label": "关于我们", "href": "/about" }
      ]
    },
    "showContactButton": {
      "type": "boolean",
      "title": "显示联系按钮",
      "default": true
    },
    "showCtaButton": {
      "type": "boolean",
      "title": "显示CTA按钮",
      "default": true
    },
    "ctaButtonText": {
      "type": "string",
      "title": "CTA按钮文本",
      "default": "开始使用"
    },
    "ctaButtonLink": {
      "type": "string",
      "title": "CTA按钮链接",
      "default": "/products"
    }
  },
  "default": {
    "navItems": [
      { "label": "首页", "href": "/" },
      { "label": "产品", "href": "/products" },
      { "label": "服务", "href": "/services" },
      { "label": "关于我们", "href": "/about" }
    ],
    "showContactButton": true,
    "showCtaButton": true,
    "ctaButtonText": "开始使用",
    "ctaButtonLink": "/products"
  }
}