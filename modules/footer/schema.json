{
  "title": "页脚配置",
  "description": "配置网站页脚信息",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "title": "公司简介",
      "ui": {"widget": "textarea", "rows": 3, "width": "100%"}
    },
    "address": {
      "type": "string",
      "title": "公司地址",
      "ui": {"widget": "input", "width": "50%"}
    },
    "phone": {
      "type": "string",
      "title": "联系电话",
      "ui": {"widget": "input", "width": "50%"}
    },
    "email": {
      "type": "string",
      "title": "电子邮箱",
      "ui": {"widget": "input", "width": "50%"}
    },
    "wechatQrCode": {
      "type": "string",
      "title": "微信二维码图片URL",
      "ui": {"widget": "input", "width": "50%"}
    },
    "officialAccountQrCode": {
      "type": "string",
      "title": "公众号二维码图片URL",
      "ui": {"widget": "input", "width": "50%"}
    },
    "showAdminLink": {
      "type": "boolean",
      "title": "显示管理后台链接",
      "default": true,
      "ui": {"widget": "switch", "width": "33%"}
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left"
  }
}
