{
  "title": "价格配置",
  "description": "配置首页价格区域的内容",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "区块标题",
      "ui": {"widget": "input", "width": "100%"}
    },
    "description": {
      "type": "string",
      "title": "区块描述",
      "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
    },
    "plans": {
      "type": "array",
      "title": "价格方案",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "title": "方案名称",
            "ui": {"widget": "input", "width": "100%"}
          },
          "price": {
            "type": "string",
            "title": "价格",
            "ui": {"widget": "input", "width": "100%"}
          },
          "description": {
            "type": "string",
            "title": "方案描述",
            "ui": {"widget": "textarea", "rows": 2, "width": "100%"}
          },
          "features": {
            "type": "array",
            "title": "功能列表",
            "items": {"type": "string"},
            "ui": {"widget": "tags", "placeholder": "输入功能后按回车添加", "width": "100%"}
          },
          "buttonText": {
            "type": "string",
            "title": "按钮文本",
            "ui": {"widget": "input", "width": "100%"}
          },
          "buttonLink": {
            "type": "string",
            "title": "按钮链接",
            "ui": {"widget": "input", "width": "100%"}
          },
          "isPopular": {
            "type": "boolean",
            "title": "是否推荐",
            "ui": {"widget": "switch", "width": "100%"}
          }
        }
      },
      "ui": {"widget": "array", "itemTitle": "价格方案", "width": "100%"}
    }
  },
  "ui": {
    "layout": "vertical",
    "labelAlign": "left"
  }
}
