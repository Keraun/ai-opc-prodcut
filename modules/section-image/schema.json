{
  "type": "object",
  "title": "图片区块配置",
  "description": "配置图片展示区块,支持移动端和Web端区分图片",
  "properties": {
    "title": {
      "type": "string",
      "title": "区块标题",
      "description": "图片区块的可选标题"
    },
    "description": {
      "type": "string",
      "title": "区块描述",
      "description": "图片区块的可选描述"
    },
    "webImage": {
      "type": "string",
      "title": "Web端图片",
      "description": "Web端显示的图片",
      "ui": {
        "widget": "image",
        "placeholder": "请上传Web端图片"
      }
    },
    "mobileImage": {
      "type": "string",
      "title": "移动端图片",
      "description": "移动端显示的图片(可选,不填则使用Web端图片)",
      "ui": {
        "widget": "image",
        "placeholder": "请上传移动端图片"
      }
    },
    "alt": {
      "type": "string",
      "title": "图片描述",
      "description": "图片的替代文本,用于无障碍访问"
    },
    "caption": {
      "type": "string",
      "title": "图片说明",
      "description": "图片下方的说明文字"
    },
    "containerPaddingX": {
      "type": "string",
      "title": "容器左右间距",
      "description": "设置外部容器的左右间距值",
      "default": "1.5rem"
    },
    "containerPaddingY": {
      "type": "string",
      "title": "容器上下间距",
      "description": "设置外部容器的上下间距值",
      "default": "0"
    },
    "containerType": {
      "type": "string",
      "title": "容器类型",
      "description": "选择图片区块的容器类型",
      "enum": ["section", "empty"],
      "default": "section"
    },
    "backgroundColor": {
      "type": "string",
      "title": "区块背景色",
      "description": "选择区块的背景颜色",
      "default": "#ffffff"
    },
    "contentLayout": {
      "type": "string",
      "title": "布局样式",
      "description": "选择图片区块的布局样式",
      "enum": ["default", "section", "article"],
      "default": "default"
    }
  }
}
